# Supabase Project Credentials
# Vind deze in: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://jouw-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=jouw-anon-key

# Optioneel: voor server-side operaties met volledige rechten
# SUPABASE_SERVICE_ROLE_KEY=jouw-service-role-key

# App URL (voor auth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mollie betalingen
# Vind je sleutels op: https://my.mollie.com/dashboard/developers/api-keys
# Gebruik test_... in ontwikkeling, live_... in productie
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Publieke basis-URL van je app (voor Mollie redirect + webhook URLs)
NEXT_PUBLIC_BASE_URL=https://jouw-domein.nl

# ── E-mail (kies één provider) ──────────────────────────────────────────────

# Optie 1: Mailjet (aanbevolen — gratis 6000/maand, geen domeinverificatie)
# Account aanmaken op https://app.mailjet.com → Account → API Keys
MAILJET_API_KEY=jouw-mailjet-api-key
MAILJET_SECRET_KEY=jouw-mailjet-secret-key
MAILJET_FROM_EMAIL=info@artiflexx.nl
MAILJET_FROM_NAME=CueBoard

# Optie 2: Resend (fallback — vereist geverifieerd domein)
# Account aanmaken op https://resend.com → API Keys
# RESEND_API_KEY=re_xxxxxxxxxxxx

# Site URL (voor links in e-mails)
NEXT_PUBLIC_SITE_URL=https://www.cueboard.nl

# Cron beveiliging (willekeurige string, zetten in Vercel én hier)
# CRON_SECRET=genereer-een-willekeurige-string
